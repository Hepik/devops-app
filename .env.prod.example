# This file lives on the EC2 host at /opt/devops-app/.env — NOT in git.
# The CI pipeline edits BACKEND_IMAGE_TAG / FRONTEND_IMAGE_TAG in-place on
# every successful deploy (sed, see .github/workflows/*.yml).

# ghcr.io/<your-github-username-or-org>/devops-task-backend
BACKEND_IMAGE_NAME=ghcr.io/CHANGE_ME/devops-task-backend
BACKEND_IMAGE_TAG=changeme

FRONTEND_IMAGE_NAME=ghcr.io/CHANGE_ME/devops-task-frontend
FRONTEND_IMAGE_TAG=changeme

POSTGRES_DB=appdb
POSTGRES_USER=appuser
# Generate a strong value for real use — see README "Секрети" section.
POSTGRES_PASSWORD=changeme
